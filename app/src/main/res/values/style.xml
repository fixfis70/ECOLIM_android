<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text appearances -->
    <style name="TextAppearance.App.Headline6" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/font_family_modern</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
    </style>

    <style name="TextAppearance.App.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/font_family_modern</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
    </style>

    <!-- Button style -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">@font/font_family_modern</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>

    <style name="Widget.App.Button.Dark" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">@font/font_family_modern</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- TextInputLayout / TextInputEditText style (light) -->
    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxStrokeColor">@color/input_stroke</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextAppearance">@style/TextAppearance.App.Hint</item>
        <item name="helperTextTextAppearance">@style/TextAppearance.App.Helper</item>
    </style>

    <style name="Widget.App.TextInputLayout.Dark" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxStrokeColor">@color/input_stroke</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextAppearance">@style/TextAppearance.App.Hint.Dark</item>
        <item name="helperTextTextAppearance">@style/TextAppearance.App.Helper.Dark</item>
    </style>

    <style name="TextAppearance.App.Hint" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/font_family_modern</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/input_hint</item>
    </style>

    <style name="TextAppearance.App.Helper" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/font_family_modern</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/input_stroke</item>
    </style>

    <style name="TextAppearance.App.Hint.Dark" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/font_family_modern</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/dark_onBackground</item>
    </style>

    <style name="TextAppearance.App.Helper.Dark" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/font_family_modern</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/dark_onBackground</item>
    </style>
</resources>